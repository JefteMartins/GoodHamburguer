@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="app-main">
        <header class="app-topbar">
            <div>
                <p class="app-topbar-kicker">Kitchen control layer</p>
                <strong>GoodHamburguer Operations</strong>
            </div>
            <div class="app-topbar-status">
                <span class="app-topbar-indicator" aria-hidden="true"></span>
                <span>API v1 online</span>
            </div>
        </header>

        <article class="content-shell">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
